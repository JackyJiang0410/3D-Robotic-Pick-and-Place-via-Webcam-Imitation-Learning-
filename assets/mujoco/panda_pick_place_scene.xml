<mujoco model="panda_pick_place_scene">
  <!-- Panda MJCF is vendored under assets/robots/mujoco_menagerie/franka_emika_panda/ -->
  <!-- When included from this scene, set meshdir explicitly so MuJoCo can find meshes. -->
  <compiler angle="radian" meshdir="../robots/mujoco_menagerie/franka_emika_panda/assets"
            texturedir="../robots/mujoco_menagerie/franka_emika_panda/assets"/>
  <include file="../robots/mujoco_menagerie/franka_emika_panda/panda.xml"/>

  <statistic center="0.35 0 0.35" extent="1.2"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-25"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge"
             rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
             markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <!-- Cameras for offscreen rendering used by --save-images in run_collect_phase1.py.
         agent_view: front-right 3/4 view that always re-aims at the cube body so the cube
                     stays in frame as it (or the gripper carrying it) moves around.
         topdown:   straight-down view; pure (x, y) pixels, useful for 2D-position policies. -->
    <camera name="agent_view" pos="1.2 -0.6 0.7" mode="targetbody" target="object" fovy="45"/>
    <camera name="topdown"    pos="0.45 0.0 1.2" xyaxes="1 0 0 0 1 0" fovy="55"/>

    <!-- Simple table.
         Stiff contact (small solref timeconst, high solimp) prevents the cube from sinking into the
         table top when the gripper presses down on it. condim=4 + non-trivial torsional friction makes
         the cube settle stably instead of jittering. -->
    <geom name="table" type="box" pos="0.45 0 0.15" size="0.35 0.25 0.15" rgba="0.82 0.78 0.74 1"
          condim="4"
          friction="2.0 0.05 0.002"
          solref="0.001 1" solimp="0.999 0.9999 0.0001"/>

    <!-- A single object to pick.
         Sized 5 cm cube and placed exactly on top of the table (table top z = 0.30, half-height 0.025 -> center z = 0.325)
         so it does NOT fall/bounce at startup.
         condim=4 + non-zero torsional friction makes the pinch grasp stable; mass is set explicitly so the
         small position-controlled gripper can lift it without slipping. -->
    <body name="object" pos="0.67 0.14 0.325">
      <freejoint name="object"/>
      <!-- Very stiff contact (1 ms time-constant, near-perfect impedance) makes the cube behave like
           a hard rigid body so the gripper pads cannot penetrate it. The grip is held by FRICTION, not
           squeeze force, so the gripper stays at near-stock stiffness in PandaPickPlaceEnv.__init__. -->
      <geom name="object_geom" type="box" size="0.025 0.025 0.025"
            rgba="0.85 0.45 0.1 1"
            mass="0.05"
            condim="4"
            friction="10.0 0.5 0.05"
            solref="0.001 1" solimp="0.999 0.9999 0.0001"/>
    </body>

    <!-- Fixed target location used by PandaPickPlaceEnv as an obs field (target_pos).
         Kept in the model so the observation vector layout stays stable, but rendered
         invisible (alpha=0) so it does not look like a stray ball on the table. -->
    <site name="target_site" pos="0.55 -0.10 0.305" size="0.015" rgba="0 1 0 0"/>
  </worldbody>
</mujoco>

